# ============================================================
# VPN Sales System — Пример конфигурации
# Скопируй в .env и заполни свои значения:
#   cp .env.example .env
# ============================================================

# ── PostgreSQL ───────────────────────────────────────────────
POSTGRES_DB=vpn_system
POSTGRES_USER=postgres
POSTGRES_PASSWORD=ИЗМЕНИ_НА_НАДЁЖНЫЙ_ПАРОЛЬ

# ── Redis ────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0

# ── Telegram Bot ─────────────────────────────────────────────
# Получи токен от @BotFather
BOT_TOKEN=1234567890:ТВОЙ_ТОКЕН_ОТ_BOTFATHER
TELEGRAM_BOT_TOKEN=1234567890:ТВОЙ_ТОКЕН_ОТ_BOTFATHER

# Твой Telegram ID (узнать: @userinfobot)
# Несколько ID через запятую: 123456,789012
ADMIN_IDS=ТВОЙ_TELEGRAM_ID
TELEGRAM_ADMIN_IDS=ТВОЙ_TELEGRAM_ID

# ── JWT ──────────────────────────────────────────────────────
# Сгенерируй: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=СГЕНЕРИРУЙ_СЛУЧАЙНЫЙ_КЛЮЧ_32_БАЙТА
JWT_ALGORITHM=HS256
SECRET_KEY=СГЕНЕРИРУЙ_СЛУЧАЙНЫЙ_КЛЮЧ_32_БАЙТА

# ── Веб-панель администратора ─────────────────────────────────
ADMIN_USERNAME=admin
ADMIN_PASSWORD=ИЗМЕНИ_ПАРОЛЬ_ВЕББПАНЕЛИ

# ── YooKassa (опционально) ────────────────────────────────────
# Зарегистрируйся на yookassa.ru и получи ключи
YOOKASSA_SHOP_ID=
YOOKASSA_SECRET_KEY=

# ── Webhook (для production с HTTPS) ─────────────────────────
# Оставь пустым для polling (разработка)
WEBHOOK_URL=
WEBHOOK_SECRET=

# ── Ссылки в боте ────────────────────────────────────────────
TELEGRAM_CHANNEL_URL=https://t.me/твой_канал
TELEGRAM_SUPPORT_URL=https://t.me/твой_поддержка

# ── VPN Mock режим ────────────────────────────────────────────
# true  = работает без VPN серверов (заглушка)
# false = требует настроенных XUI серверов
VPN_MOCK_MODE=true

# ── Реферальная программа ─────────────────────────────────────
REFERRAL_BONUS_DAYS=7
FREE_TRIAL_HOURS=24
FREE_TRIAL_TRAFFIC_GB=10

# ── API ───────────────────────────────────────────────────────
API_BASE_URL=http://backend:8000/api
API_KEY=

# ── Режим работы ─────────────────────────────────────────────
# Для production: DEBUG=False
DEBUG=False
LOG_LEVEL=INFO
